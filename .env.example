# 环境配置模板
# 复制此文件为 .env 并修改对应值：cp .env.example .env

# 运行环境（development / production）
NODE_ENV=development

# 服务端口
PORT=3000

# JWT 密钥（⚠️ 生产环境务必修改为随机字符串，建议 32 位以上）
JWT_SECRET=your-secret-key-please-change

# JWT 过期时间（如 7d = 7天）
JWT_EXPIRES_IN=7d

# 管理员默认账号（仅首次初始化时生效）
ADMIN_USERNAME=admin

# 管理员默认密码（仅首次初始化时生效，⚠️ 首次登录后请立即修改）
ADMIN_PASSWORD=admin123

# 上传文件大小限制（字节，默认 5MB）
UPLOAD_MAX_SIZE=5242880

# 上传允许的文件类型（逗号分隔）
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# 邮件服务配置（用于联系表单通知，留空则不发送邮件）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
